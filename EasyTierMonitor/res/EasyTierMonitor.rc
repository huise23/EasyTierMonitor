IDD_CONFIG_DIALOG DIALOGEX 0, 0, 320, 120
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "EasyTierMonitor Configuration"
FONT 9, "MS Shell Dlg", 400, 0, 0x1
BEGIN
    LTEXT           "Select Peer:",IDC_STATIC_PEER,10,10,70,10
    COMBOBOX        IDC_PEER_COMBO,10,25,300,120,CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    PUSHBUTTON      "Refresh List",IDC_REFRESH_PEER_LIST,240,48,70,14

    CONTROL         "Auto Rotate Peers",IDC_ENABLE_NOTIFICATION_CHECK,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,10,75,100,10

    DEFPUSHBUTTON   "OK",IDOK,150,90,50,14
    PUSHBUTTON      "Cancel",IDCANCEL,210,90,50,14
END

IDD_HISTORY_DIALOG DIALOGEX 0, 0, 500, 350
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "EasyTier Monitor - 历史记录"
FONT 9, "MS Shell Dlg", 400, 0, 0x1
BEGIN
