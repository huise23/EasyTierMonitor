    PUSHBUTTON      "Export...",IDC_EXPORT_BUTTON,320,220,75,14
    PUSHBUTTON      "Refresh",IDC_REFRESH_BUTTON,405,220,75,14

    DEFPUSHBUTTON   "Close",IDOK,420,300,50,14
END

